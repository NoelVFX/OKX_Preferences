# Public web server
PORT=4242
# Set this to your final HTTPS URL, for example https://203-0-113-10.sslip.io
DOMAIN=https://your-public-domain.example
# The Discord coordinator uses this as the Checkout/webhook base URL. Keep it equal to DOMAIN in cloud.
NGROK_URL=https://your-public-domain.example

# Stripe test/live keys
STRIPE_SECRET_KEY=sk_test_...
# Create this after adding the Stripe webhook endpoint: https://your-domain/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Preferences AI
PREFERENCES_API_BASE=https://dashboard.preferencesai.io/api/v1
PREFERENCES_AI_API_KEY=...
PREFERENCES_SIMULATION_PRU_COST=29
PREFERENCES_REQUEST_TIMEOUT=180

# Hermes preview generation
# On a minimal cloud VM, keep this off unless Hermes CLI is installed/configured there.
HERMES_PREVIEW_USE_CLI=0
HERMES_COMMAND=hermes
HERMES_PREVIEW_TIMEOUT=90
# On Vercel, skip the CLI and call a hosted chat API directly instead (see README
# "Vercel deployment notes"). Gemini has a free tier; OpenAI requires paid credits.
# HERMES_PROVIDER=gemini-api
# HERMES_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=...

# Discord bot/coordinator. Required only if running agent_coordinator.py.
DISCORD_BOT_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional app behavior
WEB_RUN_LIVE_SIMULATION=1
WEB_REQUIRE_PAYMENT_FOR_DASHBOARD_LINKS=1
WEB_PRICE_CENTS=999
WEB_PRICE_CURRENCY=usd
WEB_PRODUCT_NAME=Preferences ASP Concierge Unlock

# Pitch deck add-on, sold on the unlocked /success page after the base unlock
WEB_PITCH_DECK_PRICE_CENTS=999
WEB_PITCH_DECK_PRODUCT_NAME=Preferences ASP Concierge Investor Pitch Deck

# --- Agent Service Provider (ASP) identity ---
# Powers the machine-readable manifest at /api/agent/manifest, /openapi.json,
# and /.well-known/ai-plugin.json used to list this backend as an agent / tool.
ASP_ID=preferences-asp-concierge
ASP_NAME=Preferences ASP Concierge
ASP_PROVIDER=Preferences AI
ASP_CONTACT_EMAIL=
# ASP_DESCRIPTION=...   # optional override of the default description
# On-chain identity for the agent (e.g. an X Layer wallet). Defaults to
# OKX_RECEIVING_ADDRESS. Set only when you have a real address to register.
# ASP_AGENT_WALLET=0x...

# --- OKX Wallet crypto payment (X Layer / USDT) ---
# REQUIRED to enable the "Pay with OKX Wallet" option: your own wallet address
# that receives USDT on X Layer. Leave unset to keep crypto payments disabled.
# Funds go here — set it to YOUR address, never a placeholder.
OKX_RECEIVING_ADDRESS=
# The rest have working X Layer defaults (verified live: chainId 196, USDT 6 decimals).
# Override only if you change chains/tokens. Verify any token contract on the explorer first.
# OKX_CHAIN_ID=196
# OKX_CHAIN_NAME=X Layer
# OKX_RPC_URL=https://rpc.xlayer.tech
# OKX_BLOCK_EXPLORER_URL=https://www.oklink.com/xlayer
# OKX_NATIVE_CURRENCY=OKB
# OKX_USDT_CONTRACT=0x1E4a5963aBFD975d8c9021ce480b42188849D41d
# OKX_USDT_DECIMALS=6
# OKX_MIN_CONFIRMATIONS=1
# The USDT price is derived from WEB_PRICE_CENTS / WEB_PITCH_DECK_PRICE_CENTS above
# (e.g. 999 => 9.99 USDT).
#
# --- Free demo mode (spend nothing, no gas, no tokens) ---
# Set OKX_TEST_MODE=1 to turn the OKX Wallet payment into a gasless SIGNATURE:
# the wallet pops up, the user signs a message (no transaction, no gas, no
# tokens), and the server verifies the signature proves they control the wallet.
# Nothing is charged, and it works without any faucet or testnet balance. Still
# set OKX_RECEIVING_ADDRESS to a valid 0x... address you control (crypto stays
# disabled until it is a valid address).
# OKX_TEST_MODE=1
