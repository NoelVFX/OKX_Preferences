{
  "version": 2,
  "buildCommand": "bash scripts/install-hermes-vercel.sh",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "functions": {
    "server.js": {
      "includeFiles": ".vercel-hermes/**",
      "maxDuration": 300
    }
  }
}
